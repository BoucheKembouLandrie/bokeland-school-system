{
    "name": "bokelandschoolsystem",
    "version": "1.0.0",
    "description": "Système de gestion scolaire BOKELAND SCHOOL SYSTEM",
    "main": "electron-main.js",
    "private": true,
    "scripts": {
        "install:all": "cd backend && npm install && cd ../frontend && npm install",
        "dev:backend": "cd backend && npm run dev",
        "dev:frontend": "cd frontend && npm run dev",
        "build:backend": "cd backend && npm run build",
        "build:frontend": "cd frontend && npm run build",
        "build:all": "npm run build:backend && npm run build:frontend",
        "electron:dev": "set NODE_ENV=development&& electron .",
        "dist": "npm run build:all && electron-builder",
        "build:installer": "node build_installer.js"
    },
    "build": {
        "appId": "com.bokeland.schoolsystem",
        "productName": "Bokeland School System",
        "win": {
            "target": [
                "nsis"
            ],
            "icon": "build/icon.png"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        },
        "publish": {
            "provider": "generic",
            "url": "https://license.leuanaschool.com/updates/"
        },
        "files": [
            "electron-main.js",
            "preload.js",
            "backend/dist/**/*",
            "frontend/dist/**/*",
            "package.json"
        ]
    },
    "keywords": [
        "school",
        "management",
        "education",
        "bokeland"
    ],
    "author": "BOKELAND SCHOOL SYSTEM",
    "license": "PROPRIETARY",
    "devDependencies": {
        "electron": "^40.0.0",
        "electron-builder": "^26.7.0",
        "electron-updater": "^6.7.3"
    }
}
